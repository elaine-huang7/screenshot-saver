{
  "expo": {
    "name": "Screenshot Saver",
    "slug": "screenshot-saver",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "screenshotsaver",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose a screenshot so Screenshot Saver can summarize it."
        }
      ]
    ]
  }
}
